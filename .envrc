# Dim direnv status messages
export DIRENV_LOG_FORMAT=$'\033[2mdirenv: %s\033[0m'

# Also rebuild if other local flake inputs change
watch_file nix/*

# Silence the git dirty-tree warning without changing flake source semantics.
if [[ "${NIX_CONFIG-}" != 'warn-dirty = false' && "${NIX_CONFIG-}" != *$'\n''warn-dirty = false'* ]]; then
  export NIX_CONFIG="${NIX_CONFIG-}"$'\n''warn-dirty = false'
fi

# Use flake
use flake
